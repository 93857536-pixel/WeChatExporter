<Window x:Class="WeChatExporter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="微信聊天记录导出"
        Width="980" Height="680" MinWidth="980" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBgBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Margin="16">
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource AppPanelBrush}"
                    CornerRadius="12" Padding="14" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Background="{StaticResource AccentBrush}" CornerRadius="10" Width="48" Height="48">
                            <TextBlock Text="💬" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="导出工具" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}"/>
                            <TextBlock Text="{Binding ExportStyleSummary}" Foreground="{DynamicResource AppMutedBrush}" FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Visibility="{Binding ShowOperationProgress, Converter={StaticResource BoolToVis}}">
                        <ProgressBar Minimum="0" Maximum="1"
                                     Value="{Binding OperationProgress, Mode=OneWay}"
                                     Height="8" Margin="0,8,0,4"/>
                        <TextBlock Text="{Binding OperationProgressLabel}" FontSize="11"
                                   Foreground="{DynamicResource AppMutedBrush}"/>
                        <TextBlock Text="{Binding OperationProgressPercentText}" FontSize="10"
                                   Foreground="{DynamicResource AppMutedBrush}" HorizontalAlignment="Right"/>
                    </StackPanel>
                    <ProgressBar Height="4" IsIndeterminate="True"
                                 Visibility="{Binding ShowIndeterminateBusy, Converter={StaticResource BoolToVis}}"
                                 Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <Button Content="设置" Padding="10,6" Margin="0,0,6,0" Click="Settings_Click"/>
                <Button Content="准备数据" Padding="10,6" Margin="0,0,6,0"
                        Click="PrepareData_Click" IsEnabled="{Binding IsBusy, Converter={StaticResource NotBool}}"/>
                <Button Content="刷新" Padding="10,6" Margin="0,0,6,0"
                        Click="Refresh_Click" IsEnabled="{Binding IsBusy, Converter={StaticResource NotBool}}"/>
                <Button Content="导出预览" Padding="10,6" Margin="0,0,6,0"
                        Click="Preview_Click" IsEnabled="{Binding CanExport}"/>
                <Button Content="导出选中" Padding="10,6" Margin="0,0,6,0"
                        Background="{StaticResource AccentBrush}" Foreground="White"
                        Click="Export_Click" IsEnabled="{Binding CanExport}"/>
                <Button Content="重试失败" Padding="10,6" Margin="0,0,6,0"
                        Click="RetryFailed_Click" IsEnabled="{Binding CanRetryFailed}"/>
                <Button Content="环境检测" Padding="10,6"
                        Click="EnvironmentCheck_Click" IsEnabled="{Binding IsBusy, Converter={StaticResource NotBool}}"/>
            </WrapPanel>

            <TextBox DockPanel.Dock="Top" Margin="0,0,0,8"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6"
                     Background="{DynamicResource AppInputBgBrush}"
                     Foreground="{DynamicResource AppTextBrush}"/>

            <TextBlock DockPanel.Dock="Top" Text="{Binding FilteredCountText}"
                       Foreground="{DynamicResource AppMutedBrush}" Margin="0,0,0,6"/>
            <CheckBox DockPanel.Dock="Top" Content="只看收藏" Margin="0,0,0,8"
                      IsChecked="{Binding ShowFavoritesOnly, Mode=TwoWay}"
                      Foreground="{DynamicResource AppTextBrush}"/>

            <ListBox x:Name="ContactList"
                     ItemsSource="{Binding ContactsView}"
                     SelectionMode="Extended"
                     Background="{DynamicResource AppPanelBrush}"
                     Foreground="{DynamicResource AppTextBrush}"
                     SelectionChanged="ContactList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="{Binding FavoriteGlyph}" Width="28" Height="28"
                                    Padding="0" Margin="0,0,8,0"
                                    Click="ToggleFavorite_Click"
                                    Foreground="{StaticResource AccentBrush}"
                                    Background="Transparent"
                                    BorderThickness="0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="Medium"
                                           Foreground="{DynamicResource AppTextBrush}"/>
                                <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource AppMutedBrush}" FontSize="11"/>
                            </StackPanel>
                            <Border Grid.Column="2" Background="{StaticResource AccentSoftBrush}"
                                    CornerRadius="10" Padding="8,3" VerticalAlignment="Center">
                                <TextBlock Text="{Binding KindLabel}" FontSize="10"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <DockPanel Grid.Column="1" Margin="20">
            <TextBlock DockPanel.Dock="Bottom"
                       Text="{Binding CreditLine}"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource AppMutedBrush}"
                       FontSize="12"
                       Margin="0,12,0,0"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="{DynamicResource AppPanelBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{Binding ReadinessHint}" TextWrapping="Wrap"
                                       Foreground="{DynamicResource AppTextBrush}"/>
                            <ProgressBar Minimum="0" Maximum="1"
                                         Value="{Binding OperationProgress, Mode=OneWay}"
                                         Height="8" Margin="0,10,0,0"
                                         Visibility="{Binding ShowOperationProgress, Converter={StaticResource BoolToVis}}"/>
                            <Button Content="以管理员身份重新启动" Margin="0,10,0,0" Padding="10,6"
                                    HorizontalAlignment="Left"
                                    Visibility="{Binding IsRunningAsAdmin, Converter={StaticResource AdminVis}}"
                                    Click="RestartAdmin_Click"/>
                        </StackPanel>
                    </Border>

                    <GroupBox Header="当前导出配置" Margin="0,0,0,16" Padding="12"
                              Foreground="{DynamicResource AppTextBrush}">
                        <StackPanel>
                            <TextBlock Text="{Binding ExportStyleSummary}" TextWrapping="Wrap"
                                       Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding ExportPath}" TextWrapping="Wrap" FontSize="12"
                                       Foreground="{DynamicResource AppMutedBrush}" Margin="0,0,0,10"/>
                            <Button Content="打开设置…" Padding="10,6" HorizontalAlignment="Left"
                                    Click="Settings_Click"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="使用说明" Margin="0,0,0,16" Padding="12"
                              Foreground="{DynamicResource AppTextBrush}">
                        <StackPanel>
                            <TextBlock Text="1. 首次使用点击「准备数据」（需微信 PC 版已登录）" Margin="0,2"
                                       Foreground="{DynamicResource AppTextBrush}"/>
                            <TextBlock Text="2. 若密钥扫描失败，请右键以管理员身份运行本程序" Margin="0,2"
                                       Foreground="{DynamicResource AppTextBrush}"/>
                            <TextBlock Text="3. 在左侧列表中选择一个或多个联系人（Ctrl 多选）" Margin="0,2"
                                       Foreground="{DynamicResource AppTextBrush}"/>
                            <TextBlock Text="4. 在「设置」中选择导出方式、主题等选项后点击「导出选中」" Margin="0,2"
                                       Foreground="{DynamicResource AppTextBrush}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="日志" Padding="12" Foreground="{DynamicResource AppTextBrush}">
                        <DockPanel MinHeight="280">
                            <TextBlock DockPanel.Dock="Top" Text="{Binding StatusText}"
                                       Foreground="{DynamicResource AppMutedBrush}"
                                       HorizontalAlignment="Right" Margin="0,0,0,8"/>
                            <ListBox ItemsSource="{Binding Logs}"
                                     Background="{DynamicResource AppInputBgBrush}"
                                     Foreground="{DynamicResource AppTextBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource AppTextBrush}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Window>
