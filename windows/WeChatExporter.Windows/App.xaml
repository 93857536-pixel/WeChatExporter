<Application x:Class="WeChatExporter.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WeChatExporter"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#07C35F"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#1A07C35F"/>
        <SolidColorBrush x:Key="AppBgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AppPanelBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="AppTextBrush" Color="#222222"/>
        <SolidColorBrush x:Key="AppMutedBrush" Color="#666666"/>
        <SolidColorBrush x:Key="AppInputBgBrush" Color="#FFFFFF"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBooleanConverter x:Key="NotBool"/>
        <local:AdminRestartVisibilityConverter x:Key="AdminVis"/>
    </Application.Resources>
</Application>
